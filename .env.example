# SecondMe OAuth2
SECONDME_CLIENT_ID=234268a6-2002-4c1c-a58b-0a99ca68223a
SECONDME_CLIENT_SECRET=your_new_secret_after_regenerate

# SecondMe API
SECONDME_BASE_URL=https://app.mindos.com/gate/lab
SECONDME_AUTH_URL=https://go.second.me/oauth/
SECONDME_TOKEN_URL=https://api.mindverse.com/gate/lab/api/oauth/token/code

# App
APP_SECRET_KEY=change_this_to_random_string
APP_PORT=3000
REDIRECT_URI=http://localhost:3000/api/auth/callback

# LLM (for Requirement Analysis + Task Decomposition)
# Option A: Kimi (recommended, free for new users)
KIMI_API_KEY=your_kimi_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Option B: OpenAI compatible
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Demo candidate Second Me access tokens (pre-authorized)
# These are the 3 pre-setup candidate accounts
CANDIDATE_A_TOKEN=lba_at_candidate_fullstack_token
CANDIDATE_B_TOKEN=lba_at_candidate_pm_token
CANDIDATE_C_TOKEN=lba_at_candidate_data_token

# Demo agent Second Me access tokens (functional agents)
AGENT_CODE_TOKEN=lba_at_agent_code_token
AGENT_CONTENT_TOKEN=lba_at_agent_content_token
AGENT_DATA_TOKEN=lba_at_agent_data_token
